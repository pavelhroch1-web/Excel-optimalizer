# Simulation state dumps (large, derived from real data or synthetic test
# scenarios, regenerable via tools/sim/xlsx_to_json.py + run_e2e.ts) - not
# source, not committed.
tools/sim/*.json

# Python bytecode cache
__pycache__/
*.pyc
node_modules/

# Timestamped backups xlsx_engine_io.backup_workbook() makes next to the
# real workbook before writing to it - not source, not committed.
workbook/*.backup_*.xlsx

# Backend secrets (APP_PASSWORD/GITHUB_TOKEN) - set as Render env vars,
# never committed. This file is only here in case anyone creates one
# locally for testing.
backend/.env

# generated tour-plan exports
TOUR_PLAN_*.xlsx

# Runtime database + local data dir — created solely by the user's import,
# never committed or distributed (contains real data on the user's machine).
*.db
*.db-wal
*.db-shm
*.sqlite
FieldForceData/

# Seed DB is a BUILD INPUT/OUTPUT, not source. Generated by tools/build_seed_db.py
# from real exports; bundled by the build. Gitignored so real data isn't
# committed to source by accident (see report: committing it is a separate,
# explicit decision).
seed/
seed_inputs/
