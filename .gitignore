# Simulation state dumps (large, derived from real data or synthetic test
# scenarios, regenerable via tools/sim/xlsx_to_json.py + run_e2e.ts) - not
# source, not committed.
tools/sim/*.json

# Python bytecode cache
__pycache__/
*.pyc
node_modules/

# Timestamped backups xlsx_engine_io.backup_workbook() makes next to the
# real workbook before writing to it - not source, not committed.
workbook/*.backup_*.xlsx
